{
  "identifier": "default",
  "description": "Default capabilities for Bike",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "updater:allow-check",
    "updater:allow-download-and-install",
    { "identifier": "fs:scope", "allow": [
      { "path": "$HOME/**" },
      { "path": "$HOME/.claude/**" },
      { "path": "$HOME/**/.git" },
      { "path": "$HOME/**/.git/**" },
      { "path": "$HOME/**/.bike" },
      { "path": "$HOME/**/.bike/**" }
    ] }
  ]
}
